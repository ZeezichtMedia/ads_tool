---
import Layout from "../../layouts/Layout.astro";
import Sidebar from "../../components/Sidebar.astro";
import CampaignTable from "../../components/CampaignTable.astro";
import {
    getLatestSnapshots,
    getBusinessOverhead,
    getCampaignSettings,
} from "../../lib/db";

const [allAdsets, overhead, settingsData] = await Promise.all([
    getLatestSnapshots(),
    getBusinessOverhead(),
    getCampaignSettings(),
]);

const settingsDict: Record<string, number> = {};
if (Array.isArray(settingsData)) {
    for (const row of settingsData) {
        settingsDict[row.campaign_name] = row.cogs;
    }
}

// Filter to only non-ACTIVE adsets (PAUSED, CAMPAIGN_PAUSED, etc.)
const adsets = allAdsets.filter((a: any) => a.effective_status !== "ACTIVE");
---

<Layout title="Inactive Campaigns">
    <Sidebar />
    <div class="main-content">
        <div class="page-header">
            <h2 class="page-title">Inactive Campaigns</h2>
            <span class="page-subtitle"
                >{adsets.length} paused / inactive adsets</span
            >
        </div>
        <CampaignTable
            adsets={adsets}
            overhead={overhead}
            campaignSettings={settingsDict}
        />
    </div>
</Layout>
