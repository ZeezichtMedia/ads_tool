---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import Icon from "../components/Icon.astro";
import { getBusinessOverhead } from "../lib/db";

let overhead: any = null;
let dbError = false;

try {
    overhead = await getBusinessOverhead();
} catch (err) {
    console.error("Failed to load overhead data:", err);
    dbError = true;
}

// Defaults
const tFixed = overhead?.transaction_fee_fixed ?? 0.25;
const tPercent = overhead?.transaction_fee_percent ?? 1.5;
const rPercent = overhead?.refund_rate_percent ?? 0;
const mPersonnel = overhead?.monthly_personnel ?? 0;
const mContracts = overhead?.monthly_contracts ?? 0;
const mOther = overhead?.monthly_other_overhead ?? 0;
---

<Layout title="Business Costs & Overhead">
    <Sidebar />

    <div class="main-content">
        <div class="header">
            <h1 class="page-title">Business Costs & Overhead</h1>
            <p class="text-muted" style="margin-top: 5px;">
                Set your fixed and variable costs to calculate true Net Profit
                in the dashboard.
            </p>
        </div>

        {
            dbError && (
                <div class="error-container" style="margin-bottom: 24px;">
                    <div class="error-card">
                        <Icon name="wifi-off" size={48} class="text-danger" />
                        <h3 class="error-title">Database Connection Error</h3>
                        <p class="error-text">Cannot connect to Supabase.</p>
                    </div>
                </div>
            )
        }

        <div class="settings-grid">
            <!-- Variable Costs -->
            <div class="settings-card">
                <h2 class="card-title">Variable Costs (Per Order)</h2>
                <p
                    class="text-muted"
                    style="font-size: 13px; margin-bottom: 16px;"
                >
                    These are deducted proportionally from your gross revenue.
                </p>

                <div class="form-group">
                    <label>Fixed Transaction Fee (€)</label>
                    <div class="input-wrapper">
                        <span class="input-prefix">€</span>
                        <input
                            type="number"
                            id="tFixed"
                            value={tFixed}
                            step="0.01"
                            min="0"
                        />
                    </div>
                    <p class="input-hint">
                        e.g. €0.25 + per transaction (Mollie/Stripe fixed fee)
                    </p>
                </div>

                <div class="form-group">
                    <label>Transaction Fee Percentage (%)</label>
                    <div class="input-wrapper">
                        <input
                            type="number"
                            id="tPercent"
                            value={tPercent}
                            step="0.01"
                            min="0"
                        />
                        <span class="input-suffix">%</span>
                    </div>
                    <p class="input-hint">e.g. 1.5% per transaction</p>
                </div>

                <div class="form-group">
                    <label>Expected Refund / Return Rate (%)</label>
                    <div class="input-wrapper">
                        <input
                            type="number"
                            id="rPercent"
                            value={rPercent}
                            step="0.01"
                            min="0"
                        />
                        <span class="input-suffix">%</span>
                    </div>
                    <p class="input-hint">
                        Percentage of revenue expected to be refunded
                    </p>
                </div>
            </div>

            <!-- Fixed Costs -->
            <div class="settings-card">
                <h2 class="card-title">Fixed Monthly Overhead</h2>
                <p
                    class="text-muted"
                    style="font-size: 13px; margin-bottom: 16px;"
                >
                    These are divided by 30.4 (average days) and deducted daily
                    from Net Profit.
                </p>

                <div class="form-group">
                    <label>Personnel (Personeel)</label>
                    <div class="input-wrapper">
                        <span class="input-prefix">€</span>
                        <input
                            type="number"
                            id="mPersonnel"
                            value={mPersonnel}
                            step="1"
                            min="0"
                        />
                        <span class="input-suffix">/ mo</span>
                    </div>
                    <p class="input-hint">Total monthly salaries</p>
                </div>

                <div class="form-group">
                    <label>Contracts & Software (Contracten)</label>
                    <div class="input-wrapper">
                        <span class="input-prefix">€</span>
                        <input
                            type="number"
                            id="mContracts"
                            value={mContracts}
                            step="1"
                            min="0"
                        />
                        <span class="input-suffix">/ mo</span>
                    </div>
                    <p class="input-hint">Shopify, apps, server costs, etc.</p>
                </div>

                <div class="form-group">
                    <label>Other Overhead (Lasten / Top-Up)</label>
                    <div class="input-wrapper">
                        <span class="input-prefix">€</span>
                        <input
                            type="number"
                            id="mOther"
                            value={mOther}
                            step="1"
                            min="0"
                        />
                        <span class="input-suffix">/ mo</span>
                    </div>
                    <p class="input-hint">Any other fixed business expenses</p>
                </div>
            </div>
        </div>

        <div class="actions-row">
            <button id="saveBtn" class="primary-btn">
                <Icon name="save" size={16} />
                Save Settings
            </button>
            <span id="saveStatus" class="save-status"></span>
        </div>
    </div>
</Layout>

<script>
    const saveBtn = document.getElementById("saveBtn");
    const saveStatus = document.getElementById("saveStatus");

    if (saveBtn) {
        saveBtn.addEventListener("click", async () => {
            saveBtn.classList.add("loading");
            saveBtn.innerText = "Saving...";
            if (saveStatus) {
                saveStatus.innerText = "";
                saveStatus.className = "save-status";
            }

            const getVal = (id: string) =>
                parseFloat(
                    (document.getElementById(id) as HTMLInputElement)?.value,
                ) || 0;

            const payload = {
                transaction_fee_fixed: getVal("tFixed"),
                transaction_fee_percent: getVal("tPercent"),
                refund_rate_percent: getVal("rPercent"),
                monthly_personnel: getVal("mPersonnel"),
                monthly_contracts: getVal("mContracts"),
                monthly_other_overhead: getVal("mOther"),
            };

            try {
                const res = await fetch("/api/update-overhead", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify(payload),
                });

                if (res.ok) {
                    if (saveStatus) {
                        saveStatus.innerText = "Settings saved successfully!";
                        saveStatus.classList.add("success");
                    }
                } else {
                    throw new Error("Failed to save");
                }
            } catch (err) {
                if (saveStatus) {
                    saveStatus.innerText = "Error saving settings.";
                    saveStatus.classList.add("error");
                }
            } finally {
                saveBtn.classList.remove("loading");
                saveBtn.innerHTML = `
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-save"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
          Save Settings
        `;
            }
        });
    }
</script>

<style>
    .settings-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 24px;
        margin-top: 24px;
    }

    .settings-card {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 24px;
    }

    .card-title {
        font-size: 18px;
        font-weight: 600;
        margin-bottom: 4px;
        color: var(--text-primary);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    label {
        display: block;
        font-size: 14px;
        font-weight: 500;
        margin-bottom: 8px;
        color: var(--text-primary);
    }

    .input-wrapper {
        display: flex;
        align-items: center;
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s;
    }

    .input-wrapper:focus-within {
        border-color: var(--accent-color);
    }

    .input-prefix,
    .input-suffix {
        padding: 0 12px;
        color: var(--text-muted);
        font-size: 14px;
        background: var(--bg-secondary);
        display: flex;
        align-items: center;
        border-right: 1px solid var(--border-color);
    }

    .input-suffix {
        border-right: none;
        border-left: 1px solid var(--border-color);
    }

    input[type="number"] {
        flex: 1;
        border: none;
        background: transparent;
        padding: 10px 12px;
        color: var(--text-primary);
        font-size: 15px;
        width: 100%;
    }

    input[type="number"]:focus {
        outline: none;
    }

    .input-hint {
        font-size: 12px;
        color: var(--text-muted);
        margin-top: 6px;
    }

    .actions-row {
        margin-top: 32px;
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .primary-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        background: var(--accent-color);
        color: white;
        border: none;
        border-radius: 8px;
        padding: 12px 24px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition:
            opacity 0.2s,
            transform 0.1s;
    }

    .primary-btn:hover {
        opacity: 0.9;
    }

    .primary-btn:active {
        transform: scale(0.98);
    }

    .primary-btn.loading {
        opacity: 0.7;
        pointer-events: none;
    }

    .save-status {
        font-size: 14px;
        font-weight: 500;
    }

    .save-status.success {
        color: var(--color-success);
    }

    .save-status.error {
        color: var(--color-danger);
    }
</style>
