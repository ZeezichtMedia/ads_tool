---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import Icon from "../components/Icon.astro";
import { getDailyTrendsData } from "../lib/db";

let trends: any[] = [];
let dbError = false;

try {
  trends = await getDailyTrendsData(60);
} catch (err) {
  console.error("Failed to load trends:", err);
  dbError = true;
}

// Compute summary stats (initial render based on 7 days)
const visibleTrends = trends.slice(-7);
const totalSpend = visibleTrends.reduce((s, d) => s + d.spend, 0);
const totalRevenue = visibleTrends.reduce((s, d) => s + d.revenue, 0);
const avgRoas = totalSpend > 0 ? totalRevenue / totalSpend : 0;
const totalPurchases = visibleTrends.reduce((s, d) => s + d.purchases, 0);
const totalAtc = visibleTrends.reduce((s, d) => s + d.atc, 0);
const daysWithData = visibleTrends.filter(d => d.spend > 0).length;

// Shopify stats
const totalOrders = visibleTrends.reduce((s, d) => s + (d.orders || 0), 0);
const shopifyRevenue = visibleTrends.reduce((s, d) => s + (d.revenue || 0), 0);
const avgOrderValue = totalOrders > 0 ? shopifyRevenue / totalOrders : 0;
---

<Layout title="Performance Trends">
  <Sidebar />

  <div class="main-content">
    <div class="page-header">
      <h2 class="page-title">Performance Trends</h2>
      <span class="page-subtitle" id="page-subtitle">Last 7 days</span>
    </div>

    {dbError ? (
      <div class="error-container">
        <div class="error-card">
          <Icon name="wifi-off" size={48} class="text-danger" />
          <h3 class="error-title">Database Connection Error</h3>
          <p class="error-text">Cannot connect to Supabase.</p>
        </div>
      </div>
    ) : (
      <>
        <!-- Summary cards -->
        <div class="trend-summary">
          <div class="summary-card">
            <span class="summary-value" id="val-spend">€{totalSpend.toFixed(2)}</span>
            <span class="summary-label">Total Spend</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-revenue">€{totalRevenue.toFixed(2)}</span>
            <span class="summary-label">Total Revenue</span>
          </div>
          <div class="summary-card">
            <span id="val-roas" class={`summary-value ${avgRoas >= 2 ? 'text-good' : avgRoas >= 1 ? 'text-warning' : 'text-danger'}`}>
              {avgRoas.toFixed(2)}x
            </span>
            <span class="summary-label">Avg ROAS</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-purchases">{totalPurchases}</span>
            <span class="summary-label">Total Purchases</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-atc">{totalAtc}</span>
            <span class="summary-label">Total ATCs</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-days">{daysWithData}</span>
            <span class="summary-label">Active Days</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-orders">{totalOrders}</span>
            <span class="summary-label">Total Orders</span>
          </div>
          <div class="summary-card">
            <span class="summary-value" id="val-aov">€{avgOrderValue.toFixed(2)}</span>
            <span class="summary-label">AOV</span>
          </div>
        </div>

        <!-- Period selector -->
        <div class="period-selector">
          <button class="period-btn" data-period="today">Vandaag</button>
          <button class="period-btn" data-period="yesterday">Gisteren</button>
          <button class="period-btn" data-period="3">3D</button>
          <button class="period-btn active" data-period="7">7D</button>
          <button class="period-btn" data-period="14">14D</button>
          <button class="period-btn" data-period="30">30D</button>
        </div>

        <!-- Charts -->
        <div class="charts-grid">
          <div class="chart-card">
            <h3 class="chart-title">
              <Icon name="euro" size={16} class="chart-icon" />
              Spend & Revenue
            </h3>
            <canvas id="chart-spend-revenue" height="220"></canvas>
          </div>
          <div class="chart-card">
            <h3 class="chart-title">
              <Icon name="target" size={16} class="chart-icon" />
              ROAS
            </h3>
            <canvas id="chart-roas" height="220"></canvas>
          </div>
          <div class="chart-card">
            <h3 class="chart-title">
              <Icon name="shopping-cart" size={16} class="chart-icon" />
              Add to Carts
            </h3>
            <canvas id="chart-atc" height="220"></canvas>
          </div>
          <div class="chart-card">
            <h3 class="chart-title">
              <Icon name="credit-card" size={16} class="chart-icon" />
              Purchases & Orders
            </h3>
            <canvas id="chart-purchases" height="220"></canvas>
          </div>
        </div>
      </>
    )}
  </div>
</Layout>

<script define:vars={{ trends }}>
  // ─── Chart rendering with hover tooltips ───────────────
  const allData = trends;
  let currentPeriod = '7';

  // Store chart metadata for hover lookups
  const chartMeta = {};

  function getVisibleData() {
    if (!allData || allData.length === 0) return [];
    
    if (currentPeriod === 'today') {
      return [allData[allData.length - 1]];
    }
    if (currentPeriod === 'yesterday') {
      return allData.length > 1 ? [allData[allData.length - 2]] : [];
    }
    const days = parseInt(currentPeriod);
    return allData.slice(-days);
  }

  function getPreviousData() {
    if (!allData || allData.length === 0) return [];
    
    if (currentPeriod === 'today') {
      return allData.length > 1 ? [allData[allData.length - 2]] : [];
    }
    if (currentPeriod === 'yesterday') {
      return allData.length > 2 ? [allData[allData.length - 3]] : [];
    }
    const days = parseInt(currentPeriod);
    const endIdx = Math.max(0, allData.length - days);
    const startIdx = Math.max(0, endIdx - days);
    return allData.slice(startIdx, endIdx);
  }

  function calcDelta(current, previous) {
    if (previous === 0 && current === 0) return { pct: 0, direction: "flat" };
    if (previous === 0) return { pct: 100, direction: "up" };
    const pct = ((current - previous) / previous) * 100;
    if (Math.abs(pct) < 1) return { pct: 0, direction: "flat" };
    return { pct: Math.abs(pct), direction: pct > 0 ? "up" : "down" };
  }

  function deltaHtml(current, previous, periodLabel = "", invertColor = false) {
    const d = calcDelta(current, previous);
    if (d.direction === "flat") return `<span class="delta-vs">vs ${periodLabel}</span>`;
    const isGood = invertColor ? d.direction === "down" : d.direction === "up";
    const color = isGood ? "#22c55e" : "#ef4444";
    const arrow = d.direction === "up" ? "↑" : "↓";
    return `<span class="delta-badge" style="color:${color}">${arrow}${d.pct.toFixed(0)}%</span> <span class="delta-vs">vs ${periodLabel}</span>`;
  }

  function updateSummaryStats() {
    const data = getVisibleData();
    const prevData = getPreviousData();
    
    let totalSpend = 0, totalRevenue = 0, totalPurchases = 0, totalAtc = 0;
    let daysWithData = 0, totalOrders = 0, shopifyRevenue = 0;

    data.forEach(d => {
      totalSpend += d.spend || 0;
      totalRevenue += d.revenue || 0;
      totalPurchases += d.purchases || 0;
      totalAtc += d.atc || 0;
      if (d.spend > 0) daysWithData++;
      totalOrders += d.orders || 0;
      shopifyRevenue += d.revenue || 0;
    });

    let prevSpend = 0, prevRevenue = 0, prevPurchases = 0, prevAtc = 0;
    let prevOrders = 0, prevShopifyRevenue = 0;

    prevData.forEach(d => {
      prevSpend += d.spend || 0;
      prevRevenue += d.revenue || 0;
      prevPurchases += d.purchases || 0;
      prevAtc += d.atc || 0;
      prevOrders += d.orders || 0;
      prevShopifyRevenue += d.revenue || 0;
    });

    const avgRoas = totalSpend > 0 ? totalRevenue / totalSpend : 0;
    const avgOrderValue = totalOrders > 0 ? shopifyRevenue / totalOrders : 0;
    const prevRoas = prevSpend > 0 ? prevRevenue / prevSpend : 0;
    const prevAov = prevOrders > 0 ? prevShopifyRevenue / prevOrders : 0;

    let periodLabel = "previous";
    if (currentPeriod === 'today') periodLabel = "yesterday";
    else if (currentPeriod === 'yesterday') periodLabel = "day before";
    else periodLabel = `prev ${currentPeriod}D`;

    const el = (id) => document.getElementById(id);
    
    if (el('val-spend')) el('val-spend').innerHTML = `€${totalSpend.toFixed(2)} ${deltaHtml(totalSpend, prevSpend, periodLabel, true)}`;
    if (el('val-revenue')) el('val-revenue').innerHTML = `€${totalRevenue.toFixed(2)} ${deltaHtml(totalRevenue, prevRevenue, periodLabel)}`;
    
    if (el('val-roas')) {
      el('val-roas').innerHTML = `${avgRoas.toFixed(2)}x ${deltaHtml(avgRoas, prevRoas, periodLabel)}`;
      el('val-roas').className = `summary-value ${avgRoas >= 2 ? 'text-good' : avgRoas >= 1 ? 'text-warning' : 'text-danger'}`;
    }
    
    if (el('val-purchases')) el('val-purchases').innerHTML = `${totalPurchases} ${deltaHtml(totalPurchases, prevPurchases, periodLabel)}`;
    if (el('val-atc')) el('val-atc').innerHTML = `${totalAtc} ${deltaHtml(totalAtc, prevAtc, periodLabel)}`;
    if (el('val-days')) el('val-days').innerHTML = daysWithData;
    if (el('val-orders')) el('val-orders').innerHTML = `${totalOrders} ${deltaHtml(totalOrders, prevOrders, periodLabel)}`;
    if (el('val-aov')) el('val-aov').innerHTML = `€${avgOrderValue.toFixed(2)} ${deltaHtml(avgOrderValue, prevAov, periodLabel)}`;
  }

  function drawChart(canvasId, datasets, options = {}) {
    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();

    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.scale(dpr, dpr);
    ctx.clearRect(0, 0, rect.width, rect.height);

    const data = getVisibleData();
    if (data.length === 0) return;

    const padding = { top: 24, right: 16, bottom: 36, left: 56 };
    const w = rect.width - padding.left - padding.right;
    const h = rect.height - padding.top - padding.bottom;

    let allValues = [];
    for (const ds of datasets) {
      allValues.push(...data.map(d => d[ds.key]));
    }
    const maxVal = Math.max(...allValues) * 1.1 || 1;
    const minVal = options.minZero !== false ? 0 : Math.min(...allValues) * 0.9;
    const range = maxVal - minVal || 1;

    // Store meta for this chart
    chartMeta[canvasId] = { data, datasets, options, padding, w, h, maxVal, minVal, range, rect };

    // Grid lines
    const borderColor = getComputedStyle(document.documentElement).getPropertyValue('--border-light').trim() || '#2a2a2e';
    const mutedColor = getComputedStyle(document.documentElement).getPropertyValue('--text-muted').trim() || '#6b7280';
    const secondaryColor = getComputedStyle(document.documentElement).getPropertyValue('--text-secondary').trim() || '#a1a1aa';

    ctx.strokeStyle = borderColor;
    ctx.lineWidth = 0.5;
    const gridLines = 4;
    for (let i = 0; i <= gridLines; i++) {
      const y = padding.top + (i / gridLines) * h;
      ctx.beginPath();
      ctx.moveTo(padding.left, y);
      ctx.lineTo(padding.left + w, y);
      ctx.stroke();

      const val = maxVal - (i / gridLines) * range;
      ctx.fillStyle = mutedColor;
      ctx.font = '10px Inter, system-ui, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(options.formatY ? options.formatY(val) : val.toFixed(0), padding.left - 8, y + 4);
    }

    // Date labels
    ctx.fillStyle = mutedColor;
    ctx.textAlign = 'center';
    
    if (data.length === 1) {
      const parts = data[0].date.split('-');
      ctx.fillText(`${parts[2]}/${parts[1]}`, padding.left + w / 2, rect.height - 8);
    } else {
      const step = Math.max(1, Math.floor(data.length / 7));
      for (let i = 0; i < data.length; i += step) {
        const x = padding.left + (i / (data.length - 1)) * w;
        const parts = data[i].date.split('-');
        ctx.fillText(`${parts[2]}/${parts[1]}`, x, rect.height - 8);
      }
    }

    // Draw lines + fill
    for (const ds of datasets) {
      ctx.beginPath();
      ctx.strokeStyle = ds.color;
      ctx.lineWidth = 2;
      ctx.lineJoin = 'round';
      ctx.lineCap = 'round';

      if (ds.dashed) ctx.setLineDash([4, 4]);
      else ctx.setLineDash([]);

      for (let i = 0; i < data.length; i++) {
        const x = data.length === 1 ? padding.left + w / 2 : padding.left + (i / (data.length - 1)) * w;
        const y = padding.top + (1 - (data[i][ds.key] - minVal) / range) * h;
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();

      if (ds.fill && data.length > 1) {
        const lastX = padding.left + w;
        ctx.lineTo(lastX, padding.top + h);
        ctx.lineTo(padding.left, padding.top + h);
        ctx.closePath();
        ctx.fillStyle = ds.color.replace(')', ', 0.08)').replace('rgb', 'rgba');
        ctx.fill();
      }

      // Dots
      ctx.setLineDash([]);
      for (let i = 0; i < data.length; i++) {
        const x = data.length === 1 ? padding.left + w / 2 : padding.left + (i / (data.length - 1)) * w;
        const y = padding.top + (1 - (data[i][ds.key] - minVal) / range) * h;
        ctx.beginPath();
        ctx.arc(x, y, data.length === 1 ? 4 : 3, 0, Math.PI * 2);
        ctx.fillStyle = ds.color;
        ctx.fill();
      }
    }

    ctx.setLineDash([]);

    // Legend
    const legendY = 12;
    let legendX = padding.left;
    for (const ds of datasets) {
      ctx.fillStyle = ds.color;
      ctx.fillRect(legendX, legendY - 4, 12, 3);
      ctx.fillStyle = secondaryColor;
      ctx.font = '10px Inter, system-ui, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(ds.label, legendX + 16, legendY);
      legendX += ctx.measureText(ds.label).width + 32;
    }
  }

  // ─── Hover overlay ──────────────────────────────────────
  function drawHoverOverlay(canvasId, hoverIndex) {
    const meta = chartMeta[canvasId];
    if (!meta) return;

    const canvas = document.getElementById(canvasId);
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const { data, datasets, options, padding, w, h, maxVal, minVal, range, rect } = meta;

    if (hoverIndex < 0 || hoverIndex >= data.length) return;

    const x = data.length === 1 ? padding.left + w / 2 : padding.left + (hoverIndex / (data.length - 1)) * w;

    // Vertical crosshair line
    ctx.save();
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.2)';
    ctx.lineWidth = 1;
    ctx.setLineDash([4, 3]);
    ctx.beginPath();
    ctx.moveTo(x, padding.top);
    ctx.lineTo(x, padding.top + h);
    ctx.stroke();
    ctx.setLineDash([]);

    // Highlighted dots
    for (const ds of datasets) {
      const val = data[hoverIndex][ds.key];
      const y = padding.top + (1 - (val - minVal) / range) * h;

      // Outer glow
      ctx.beginPath();
      ctx.arc(x, y, 7, 0, Math.PI * 2);
      ctx.fillStyle = ds.color.replace(')', ', 0.25)').replace('rgb', 'rgba');
      ctx.fill();

      // Inner dot
      ctx.beginPath();
      ctx.arc(x, y, 4.5, 0, Math.PI * 2);
      ctx.fillStyle = ds.color;
      ctx.fill();
      ctx.strokeStyle = '#1a1a1f';
      ctx.lineWidth = 1.5;
      ctx.stroke();
    }
    ctx.restore();

    // ─── Tooltip ────────────────────────────────────────
    const day = data[hoverIndex];
    const parts = day.date.split('-');
    const dateStr = `${parts[2]}/${parts[1]}/${parts[0]}`;

    // Measure tooltip
    ctx.font = 'bold 11px Inter, system-ui, sans-serif';
    const headerWidth = ctx.measureText(dateStr).width;
    ctx.font = '11px Inter, system-ui, sans-serif';

    const lines = datasets.map(ds => {
      const val = day[ds.key];
      const formatted = options.formatY
        ? options.formatY(val)
        : (Number.isInteger(val) ? val.toString() : val.toFixed(2));
      return { label: ds.label, value: formatted, color: ds.color };
    });

    let maxLineWidth = headerWidth;
    for (const line of lines) {
      const lineW = ctx.measureText(`${line.label}: ${line.value}`).width + 16;
      if (lineW > maxLineWidth) maxLineWidth = lineW;
    }

    const tooltipW = maxLineWidth + 24;
    const tooltipH = 28 + lines.length * 20;
    const tooltipPad = 12;

    // Position: try right of point, flip if near edge
    let tooltipX = x + 14;
    if (tooltipX + tooltipW > rect.width - 8) {
      tooltipX = x - tooltipW - 14;
    }
    let tooltipY = padding.top + 10;

    // Draw tooltip background
    ctx.save();
    ctx.shadowColor = 'rgba(0, 0, 0, 0.4)';
    ctx.shadowBlur = 12;
    ctx.shadowOffsetY = 4;

    // Rounded rect
    const r = 8;
    ctx.beginPath();
    ctx.moveTo(tooltipX + r, tooltipY);
    ctx.lineTo(tooltipX + tooltipW - r, tooltipY);
    ctx.quadraticCurveTo(tooltipX + tooltipW, tooltipY, tooltipX + tooltipW, tooltipY + r);
    ctx.lineTo(tooltipX + tooltipW, tooltipY + tooltipH - r);
    ctx.quadraticCurveTo(tooltipX + tooltipW, tooltipY + tooltipH, tooltipX + tooltipW - r, tooltipY + tooltipH);
    ctx.lineTo(tooltipX + r, tooltipY + tooltipH);
    ctx.quadraticCurveTo(tooltipX, tooltipY + tooltipH, tooltipX, tooltipY + tooltipH - r);
    ctx.lineTo(tooltipX, tooltipY + r);
    ctx.quadraticCurveTo(tooltipX, tooltipY, tooltipX + r, tooltipY);
    ctx.closePath();

    ctx.fillStyle = 'rgba(22, 22, 28, 0.95)';
    ctx.fill();
    ctx.shadowColor = 'transparent';
    ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Header (date)
    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 11px Inter, system-ui, sans-serif';
    ctx.textAlign = 'left';
    ctx.fillText(dateStr, tooltipX + tooltipPad, tooltipY + 18);

    // Values
    ctx.font = '11px Inter, system-ui, sans-serif';
    lines.forEach((line, i) => {
      const lineY = tooltipY + 38 + i * 20;

      // Color dot
      ctx.beginPath();
      ctx.arc(tooltipX + tooltipPad + 4, lineY - 3, 4, 0, Math.PI * 2);
      ctx.fillStyle = line.color;
      ctx.fill();

      // Label
      ctx.fillStyle = '#a1a1aa';
      ctx.fillText(`${line.label}:`, tooltipX + tooltipPad + 14, lineY);

      // Value (right-aligned-ish)
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 11px Inter, system-ui, sans-serif';
      const labelW = ctx.measureText(`${line.label}: `).width;
      ctx.fillText(line.value, tooltipX + tooltipPad + 14 + labelW + 4, lineY);
      ctx.font = '11px Inter, system-ui, sans-serif';
    });

    ctx.restore();
  }

  // ─── Chart configs ──────────────────────────────────────
  const chartConfigs = [
    {
      id: 'chart-spend-revenue',
      datasets: [
        { key: 'spend', label: 'Spend', color: 'rgb(239, 68, 68)', fill: true },
        { key: 'revenue', label: 'Revenue', color: 'rgb(34, 197, 94)', fill: true },
      ],
      options: { formatY: v => `€${v.toFixed(0)}` },
    },
    {
      id: 'chart-roas',
      datasets: [
        { key: 'roas', label: 'ROAS', color: 'rgb(59, 130, 246)', fill: true },
      ],
      options: { formatY: v => `${v.toFixed(1)}x` },
    },
    {
      id: 'chart-atc',
      datasets: [
        { key: 'atc', label: 'Add to Carts', color: 'rgb(168, 85, 247)', fill: true },
      ],
      options: {},
    },
    {
      id: 'chart-purchases',
      datasets: [
        { key: 'purchases', label: 'Meta Purchases', color: 'rgb(249, 115, 22)', fill: true },
        { key: 'orders', label: 'Shopify Orders', color: 'rgb(34, 197, 94)', dashed: true },
      ],
      options: {},
    },
  ];

  function renderAllCharts() {
    for (const cfg of chartConfigs) {
      drawChart(cfg.id, cfg.datasets, cfg.options);
    }
  }

  // ─── Mouse event listeners for each chart ───────────────
  function setupHover(cfg) {
    const canvas = document.getElementById(cfg.id);
    if (!canvas) return;

    canvas.style.cursor = 'crosshair';

    canvas.addEventListener('mousemove', (e) => {
      const meta = chartMeta[cfg.id];
      if (!meta) return;

      const canvasRect = canvas.getBoundingClientRect();
      const mouseX = e.clientX - canvasRect.left;
      const { data, padding, w } = meta;

      // Find nearest data index
      const chartLeft = padding.left;
      const relX = mouseX - chartLeft;
      if (relX < -10 || relX > w + 10 || data.length < 1) {
        // Redraw without hover
        drawChart(cfg.id, cfg.datasets, cfg.options);
        return;
      }

      if (data.length === 1) {
        if (relX > w/2 - 30 && relX < w/2 + 30) {
          drawChart(cfg.id, cfg.datasets, cfg.options);
          drawHoverOverlay(cfg.id, 0);
        } else {
          drawChart(cfg.id, cfg.datasets, cfg.options);
        }
        return;
      }

      const ratio = Math.max(0, Math.min(1, relX / w));
      const idx = Math.round(ratio * (data.length - 1));

      // Redraw base chart + overlay
      drawChart(cfg.id, cfg.datasets, cfg.options);
      drawHoverOverlay(cfg.id, idx);
    });

    canvas.addEventListener('mouseleave', () => {
      drawChart(cfg.id, cfg.datasets, cfg.options);
    });
  }

  // Period selector
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentPeriod = btn.dataset.period;
      
      const subtitle = document.getElementById('page-subtitle');
      if (subtitle) {
        if (currentPeriod === 'today') subtitle.innerText = 'Vandaag';
        else if (currentPeriod === 'yesterday') subtitle.innerText = 'Gisteren';
        else subtitle.innerText = `Last ${currentPeriod} days`;
      }

      updateSummaryStats();
      renderAllCharts();
    });
  });

  // Initial render setup based on logic above
  updateSummaryStats();
  renderAllCharts();
  chartConfigs.forEach(setupHover);

  // Resize handler
  window.addEventListener('resize', renderAllCharts);
</script>

<style>
  :global(.delta-badge) {
    font-size: 11px;
    font-weight: 600;
    margin-left: 6px;
    vertical-align: auto;
  }
  
  :global(.delta-vs) {
    font-size: 10px;
    font-weight: 500;
    color: var(--text-muted);
    margin-left: 4px;
    vertical-align: auto;
    text-transform: lowercase;
  }

  .trend-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }

  .summary-card {
