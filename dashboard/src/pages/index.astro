---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import InfoBanner from "../components/InfoBanner.astro";
import FilterBar from "../components/FilterBar.astro";
import DateRangePicker from "../components/DateRangePicker.astro";
import CampaignTable from "../components/CampaignTable.astro";
import Icon from "../components/Icon.astro";
import {
  getSnapshotsForRange,
  getStatsForRange,
  resolveRange,
  getBusinessOverhead,
  getCampaignSettings,
} from "../lib/db";
import {
  classifyPerformance,
  STATUS_ORDER,
  STATUS_COLORS,
} from "../utils/classify";

// ─── Read URL params for date range ─────────────────────
const url = new URL(Astro.request.url);
const rangeKey = url.searchParams.get("range") || "today";
const customFrom = url.searchParams.get("from") || "";
const customTo = url.searchParams.get("to") || "";

const range = resolveRange(rangeKey, customFrom, customTo);

let adsets: any[] = [];
let stats: any = {
  alertsToday: 0,
  activeAdsets: 0,
  totalSpend: 0,
  totalAtc: 0,
  totalPurchases: 0,
  shopifyRevenue: 0,
  shopifyOrderCount: 0,
  roas: 0,
  hasShopifyData: false,
};
let overhead: any = null;
let campaignSettings: Record<string, number> = {};
let dbError = false;

try {
  const [adsetsData, statsData, overheadData, settingsData] = await Promise.all(
    [
      getSnapshotsForRange(range),
      getStatsForRange(range),
      getBusinessOverhead(),
      getCampaignSettings(),
    ],
  );
  adsets = adsetsData;
  stats = statsData;
  overhead = overheadData;

  const settingsDict: Record<string, number> = {};
  if (Array.isArray(settingsData)) {
    for (const row of settingsData) {
      settingsDict[row.campaign_name] = row.cogs;
    }
  }
  campaignSettings = settingsDict;
} catch (err) {
  console.error("Failed to load dashboard data:", err);
  dbError = true;
}

// Calculate true profit for the dashboard
const estimatedAOV = 35;
let calculatedRevenue = stats.shopifyRevenue || 0;
if (!stats.hasShopifyData) {
  calculatedRevenue = stats.totalPurchases * estimatedAOV;
}

let totalCogs = 0;
for (const a of adsets) {
  const cogs = campaignSettings[a.campaign_name] || 0;
  totalCogs += cogs * (parseInt(a.purchases) || 0);
}

const transactionFeePercent = overhead?.transaction_fee_percent || 0;
const transactionFeeFixed = overhead?.transaction_fee_fixed || 0;
const refundRatePercent = overhead?.refund_rate_percent || 0;

const totalTransactionFees =
  calculatedRevenue * (transactionFeePercent / 100) +
  (stats.totalPurchases || 0) * transactionFeeFixed;
const totalEstimatedRefunds = calculatedRevenue * (refundRatePercent / 100);

let daysInRange = 1;
if (range.from !== range.to) {
  const start = new Date(range.from);
  const end = new Date(range.to);
  daysInRange = Math.max(
    1,
    Math.ceil((end.getTime() - start.getTime()) / (1000 * 3600 * 24)),
  );
} else if (rangeKey === "yesterday" || rangeKey === "today") {
  daysInRange = 1;
} else if (rangeKey === "last7days") {
  daysInRange = 7;
} else if (rangeKey === "last30days") {
  daysInRange = 30;
} else if (rangeKey === "thismonth") {
  const today = new Date();
  daysInRange = today.getDate();
}
const monthlyFixedCosts =
  (parseFloat(overhead?.monthly_personnel) || 0) +
  (parseFloat(overhead?.monthly_contracts) || 0) +
  (parseFloat(overhead?.monthly_other_overhead) || 0);
const dailyOverhead = monthlyFixedCosts / 30.44; // Average days in a month
const totalFixedOverhead = dailyOverhead * daysInRange;

const netProfit =
  calculatedRevenue -
  stats.totalSpend -
  totalCogs -
  totalTransactionFees -
  totalEstimatedRefunds -
  totalFixedOverhead;

// Count per status for filter pills
const statusMap = new Map<string, number>();
for (const a of adsets) {
  const s = classifyPerformance(
    a,
    campaignSettings[a.campaign_name] || 0,
    overhead,
  );
  statusMap.set(s, (statusMap.get(s) || 0) + 1);
}

const statusCounts = STATUS_ORDER.filter((s) => statusMap.has(s)).map((s) => ({
  status: s,
  count: statusMap.get(s) || 0,
  ...STATUS_COLORS[s],
}));
---

<Layout title="Campaigns">
  <Sidebar />

  <div class="main-content">
    {
      dbError ? (
        <div class="error-container">
          <div class="error-card">
            <Icon name="wifi-off" size={48} class="text-danger" />
            <h3 class="error-title">Database Connection Error</h3>
            <p class="error-text">
              Cannot connect to Supabase. Check your SUPABASE_URL and
              SUPABASE_ANON_KEY.
            </p>
          </div>
        </div>
      ) : (
        <>
          <DateRangePicker
            currentRange={rangeKey}
            customFrom={customFrom}
            customTo={customTo}
          />

          <InfoBanner
            totalSpend={stats.totalSpend}
            totalRevenue={stats.shopifyRevenue || calculatedRevenue}
            roas={stats.roas}
            netProfit={netProfit}
            matchedCount={adsets.length}
            totalCount={adsets.length}
            alertsToday={stats.alertsToday}
            totalAtc={stats.totalAtc}
            totalPurchases={stats.totalPurchases}
            shopifyOrders={stats.shopifyOrderCount}
            hasShopifyData={stats.hasShopifyData}
          />

          <FilterBar
            statusCounts={statusCounts}
            totalCampaigns={adsets.length}
          />

          <CampaignTable
            adsets={adsets}
            overhead={overhead}
            campaignSettings={campaignSettings}
          />
        </>
      )
    }
  </div>
</Layout>
