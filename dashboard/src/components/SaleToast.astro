---
/**
 * SaleToast.astro — Global sale notification popup
 * Polls Supabase for new orders every 30s and shows a toast in the top-right.
 * Included in Layout.astro so it works on every page.
 */
const SUPABASE_URL = import.meta.env.SUPABASE_URL || "";
const SUPABASE_KEY = import.meta.env.SUPABASE_ANON_KEY || "";
---

<div id="sale-toast-container"></div>

<script define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
    (function () {
        const container = document.getElementById("sale-toast-container");
        if (!container) return;

        let lastSeenId = null;
        let isInitialLoad = true;

        // Fetch the most recent order
        async function checkForNewOrders() {
            try {
                const res = await fetch(
                    `${SUPABASE_URL}/rest/v1/shopify_orders?order=created_at.desc&limit=1&select=id,order_name,total_price,customer_name,line_items,created_at`,
                    {
                        headers: {
                            apikey: SUPABASE_KEY,
                            Authorization: `Bearer ${SUPABASE_KEY}`,
                        },
                    },
                );
                const orders = await res.json();
                if (!Array.isArray(orders) || orders.length === 0) return;

                const latest = orders[0];

                // On first load, don't show toast — just record the latest ID
                if (isInitialLoad) {
                    lastSeenId = latest.id;
                    isInitialLoad = false;
                    return;
                }

                // Only show toast for genuinely NEW orders
                if (latest.id !== lastSeenId) {
                    lastSeenId = latest.id;
                    showSaleToast(latest);
                }
            } catch (err) {
                // Silently fail — don't break the dashboard
            }
        }

        function showSaleToast(order) {
            const items = order.line_items || [];
            const itemNames = items
                .map((i) => i.title)
                .slice(0, 2)
                .join(", ");
            const extra = items.length > 2 ? ` +${items.length - 2} more` : "";

            const toast = document.createElement("div");
            toast.className = "sale-toast sale-toast--enter";
            toast.innerHTML = `
            <div class="sale-toast__icon">🎉</div>
            <div class="sale-toast__body">
                <div class="sale-toast__title">New Sale!</div>
                <div class="sale-toast__order">${order.order_name} · €${parseFloat(order.total_price || 0).toFixed(2)}</div>
                <div class="sale-toast__detail">${order.customer_name || "Customer"} — ${itemNames}${extra}</div>
            </div>
            <button class="sale-toast__close" onclick="this.parentElement.remove()">✕</button>
        `;

            container.appendChild(toast);

            // Trigger enter animation
            requestAnimationFrame(() => {
                toast.classList.remove("sale-toast--enter");
                toast.classList.add("sale-toast--visible");
            });

            // Auto-dismiss after 8 seconds
            setTimeout(() => {
                toast.classList.remove("sale-toast--visible");
                toast.classList.add("sale-toast--exit");
                setTimeout(() => toast.remove(), 400);
            }, 8000);
        }

        // Poll every 30 seconds
        checkForNewOrders();
        setInterval(checkForNewOrders, 30000);
    })();
</script>

<style is:global>
    #sale-toast-container {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
    }

    .sale-toast {
        pointer-events: all;
        display: flex;
        align-items: flex-start;
        gap: 12px;
        background: linear-gradient(
            135deg,
            rgba(22, 163, 74, 0.95),
            rgba(16, 120, 55, 0.95)
        );
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 12px;
        padding: 14px 16px;
        min-width: 300px;
        max-width: 380px;
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.4),
            0 0 40px rgba(34, 197, 94, 0.15);
        backdrop-filter: blur(12px);
        transform: translateX(120%);
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .sale-toast--visible {
        transform: translateX(0);
        opacity: 1;
    }

    .sale-toast--enter {
        transform: translateX(120%);
        opacity: 0;
    }

    .sale-toast--exit {
        transform: translateX(120%);
        opacity: 0;
    }

    .sale-toast__icon {
        font-size: 28px;
        line-height: 1;
        flex-shrink: 0;
        animation: saleBounce 0.6s ease 0.3s;
    }

    @keyframes saleBounce {
        0%,
        100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.3);
        }
    }

    .sale-toast__body {
        flex: 1;
        min-width: 0;
    }

    .sale-toast__title {
        font-size: 13px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 3px;
    }

    .sale-toast__order {
        font-size: 16px;
        font-weight: 700;
        color: white;
        font-feature-settings: "tnum";
    }

    .sale-toast__detail {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.8);
        margin-top: 2px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .sale-toast__close {
        background: none;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        font-size: 14px;
        padding: 2px 6px;
        border-radius: 4px;
        flex-shrink: 0;
        transition: all 0.15s;
    }

    .sale-toast__close:hover {
        color: white;
        background: rgba(255, 255, 255, 0.15);
    }
</style>
