---
interface Props {
    severity: string;
}

const { severity } = Astro.props;

const config: Record<string, { label: string; classes: string }> = {
    critical: {
        label: "CRITICAL",
        classes: "bg-red-500/20 text-red-400 border-red-500/30 ring-red-500/20",
    },
    high: {
        label: "HIGH",
        classes:
            "bg-orange-500/20 text-orange-400 border-orange-500/30 ring-orange-500/20",
    },
    medium: {
        label: "MEDIUM",
        classes:
            "bg-amber-500/20 text-amber-400 border-amber-500/30 ring-amber-500/20",
    },
    low: {
        label: "LOW",
        classes:
            "bg-green-500/20 text-green-400 border-green-500/30 ring-green-500/20",
    },
};

const { label, classes } = config[severity] || config.medium;
---

<span
    class:list={[
        "inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold tracking-wide ring-1",
        classes,
    ]}
>
    {label}
</span>
